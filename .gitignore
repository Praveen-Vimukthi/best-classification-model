# =========================
# Python / Flask
# =========================

# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
ENV/
.venv/

# Environment variables (VERY IMPORTANT)
.env
.env.*

# Flask instance folder
instance/

# Logs
*.log

# SQLite database (if used)
*.sqlite3
*.db

# =========================
# Machine Learning
# =========================

# Model files (can be large)
*.pkl
*.joblib
*.h5
*.model

# Data files (optional - ignore if large/private)
datasets/
data/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# =========================
# React / Frontend
# =========================

# Node modules (VERY IMPORTANT)
node_modules/

# Build outputs
build/
dist/

# React environment variables
.env.local
.env.development.local
.env.test.local
.env.production.local

# =========================
# System / OS files
# =========================

# Mac
.DS_Store

# Windows
Thumbs.db
desktop.ini

# =========================
# IDE / Editor
# =========================

# VS Code
.vscode/

# JetBrains (PyCharm, WebStorm)
.idea/

# =========================
# Testing / Coverage
# =========================

coverage/
*.coverage
htmlcov/

# =========================
# Misc
# =========================

# Temporary files
*.tmp
*.temp

# Cache folders
.cache/
